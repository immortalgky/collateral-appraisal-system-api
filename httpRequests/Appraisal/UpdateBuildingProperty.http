### ===========================================
### Update Building Property - With surfaces
### ===========================================
PUT {{baseUrl}}/appraisals/{{appraisalId}}/properties/{{propertyId}}/building-detail
Content-Type: application/json

{
  "surfaces": [
    {
      "fromFloorNumber": 1,
      "toFloorNumber": 1,
      "floorType": "Normal",
      "floorStructureType": "KSL",
      "floorSurfaceType": "Granite"
    },
    {
      "fromFloorNumber": 2,
      "toFloorNumber": 2,
      "floorType": "Normal",
      "floorStructureType": "Wood",
      "floorSurfaceType": "Wood"
    }
  ]
}

### ===========================================
### Update Building Property - Update existing surface (by Id)
### Replace the id with actual surface ID
### ===========================================
PUT {{baseUrl}}/appraisals/{{appraisalId}}/properties/{{propertyId}}/building-detail
Content-Type: application/json

{
  "surfaces": [
    {
      "id": "00000000-0000-0000-0000-000000000001",
      "fromFloorNumber": 1,
      "toFloorNumber": 2,
      "floorType": "Normal",
      "floorStructureType": "KSL",
      "floorSurfaceType": "Ceramic"
    }
  ]
}

### ===========================================
### Update Building Property - Clear all depreciation details
### (send empty array to remove all)
### ===========================================
PUT {{baseUrl}}/appraisals/{{appraisalId}}/properties/{{propertyId}}/building-detail
Content-Type: application/json

{
  "depreciationDetails": []
}
