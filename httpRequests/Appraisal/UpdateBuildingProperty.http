### Replace these with actual IDs from your database
@appraisalId = 00000000-0000-0000-0000-000000000000
@propertyId = 00000000-0000-0000-0000-000000000000

### ===========================================
### Update Building Property - Basic fields only
### ===========================================
PUT {{baseUrl}}/appraisals/{{appraisalId}}/properties/{{propertyId}}/building-detail
Content-Type: application/json

{
  "propertyName": "Updated Villa Name",
  "buildingAge": 6,
  "remark": "Updated remark"
}

### ===========================================
### Update Building Property - With depreciation (Period mode)
### ===========================================
PUT {{baseUrl}}/appraisals/{{appraisalId}}/properties/{{propertyId}}/building-detail
Content-Type: application/json

{
  "propertyName": "Green Valley Villa 42",
  "buildingNumber": "42/1",
  "buildingAge": 5,
  "constructionYear": 2021,
  "totalBuildingArea": 350.50,
  "sellingPrice": 12000000.00,
  "forcedSalePrice": 9000000.00,

  "depreciationDetails": [
    {
      "depreciationMethod": "Period",
      "areaDescription": "Main building - 2 floors",
      "area": 350.50,
      "year": 5,
      "isBuilding": true,
      "pricePerSqMBeforeDepreciation": 12000.00,
      "priceBeforeDepreciation": 4206000.00,
      "pricePerSqMAfterDepreciation": 10800.00,
      "priceAfterDepreciation": 3785400.00,
      "depreciationYearPct": 2.0000,
      "totalDepreciationPct": 10.0000,
      "priceDepreciation": 420600.00,
      "depreciationPeriods": [
        {
          "atYear": 1,
          "toYear": 3,
          "depreciationPerYear": 1.5000,
          "totalDepreciationPct": 4.5000,
          "priceDepreciation": 189270.00
        },
        {
          "atYear": 4,
          "toYear": 5,
          "depreciationPerYear": 2.7500,
          "totalDepreciationPct": 5.5000,
          "priceDepreciation": 231330.00
        }
      ]
    }
  ]
}

