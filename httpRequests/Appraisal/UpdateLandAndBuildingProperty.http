### Replace these with actual IDs from your database
@appraisalId = 00000000-0000-0000-0000-000000000000
@propertyId = 00000000-0000-0000-0000-000000000000

### ===========================================
### Update Land & Building - Basic fields only
### ===========================================
PUT {{baseUrl}}/appraisals/{{appraisalId}}/properties/{{propertyId}}/land-and-building-detail
Content-Type: application/json

{
  "propertyName": "Updated Estate Name",
  "buildingAge": 6,
  "landRemark": "Updated land remark",
  "buildingRemark": "Updated building remark"
}

### ===========================================
### Update Land & Building - With depreciation (Period mode)
### ===========================================
PUT {{baseUrl}}/appraisals/{{appraisalId}}/properties/{{propertyId}}/land-and-building-detail
Content-Type: application/json

{
  "propertyName": "Green Valley Premium Villa",
  "totalBuildingArea": 380.00,
  "sellingPrice": 25000000.00,
  "forcedSalePrice": 20000000.00,

  "depreciationDetails": [
    {
      "depreciationMethod": "Period",
      "areaDescription": "Main villa - 2 floors",
      "area": 380.00,
      "year": 5,
      "isBuilding": true,
      "pricePerSqMBeforeDepreciation": 15000.00,
      "priceBeforeDepreciation": 5700000.00,
      "pricePerSqMAfterDepreciation": 13500.00,
      "priceAfterDepreciation": 5130000.00,
      "depreciationYearPct": 2.0000,
      "totalDepreciationPct": 10.0000,
      "priceDepreciation": 570000.00,
      "depreciationPeriods": [
        {
          "atYear": 1,
          "toYear": 3,
          "depreciationPerYear": 1.5000,
          "totalDepreciationPct": 4.5000,
          "priceDepreciation": 256500.00
        },
        {
          "atYear": 4,
          "toYear": 5,
          "depreciationPerYear": 2.7500,
          "totalDepreciationPct": 5.5000,
          "priceDepreciation": 313500.00
        }
      ]
    }
  ]
}

