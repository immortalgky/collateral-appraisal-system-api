### ===========================================
### Update Land & Building - With surfaces
### ===========================================
PUT {{baseUrl}}/appraisals/{{appraisalId}}/properties/{{propertyId}}/land-and-building-detail
Content-Type: application/json

{
  "surfaces": [
    {
      "fromFloorNumber": 1,
      "toFloorNumber": 1,
      "floorType": "Normal",
      "floorStructureType": "KSL",
      "floorSurfaceType": "Granite"
    },
    {
      "fromFloorNumber": 2,
      "toFloorNumber": 2,
      "floorType": "Normal",
      "floorStructureType": "Wood",
      "floorSurfaceType": "Wood"
    }
  ]
}

### ===========================================
### Update Land & Building - Clear all depreciation details
### (send empty array to remove all)
### ===========================================
PUT {{baseUrl}}/appraisals/{{appraisalId}}/properties/{{propertyId}}/land-and-building-detail
Content-Type: application/json

{
  "depreciationDetails": []
}
