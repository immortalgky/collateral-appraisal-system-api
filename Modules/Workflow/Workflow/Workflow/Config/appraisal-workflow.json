{
  "name": "Collateral Appraisal Workflow",
  "description": "Complete appraisal workflow from initiation check through approval",
  "category": "Appraisal",
  "createdBy": "system-admin",
  "workflowSchema": {
    "id": "appraisal-workflow",
    "name": "Collateral Appraisal Workflow",
    "description": "Complete appraisal workflow from initiation check through approval",
    "category": "Appraisal",
    "activities": [
      {
        "id": "start",
        "name": "Workflow Start",
        "type": "StartActivity",
        "description": "Initial workflow entry point",
        "properties": {},
        "position": {
          "x": 100,
          "y": 100
        },
        "requiredRoles": [],
        "isStartActivity": true,
        "isEndActivity": false
      },
      {
        "id": "appraisal-initiation-check",
        "name": "Appraisal Initiation Check",
        "type": "TaskActivity",
        "description": "Request checker reviews the initiated appraisal request for completeness and accuracy",
        "properties": {
          "activityName": "InitiationCheck",
          "assigneeGroup": "RequestChecker",
          "assignmentStrategies": "started_by",
          "initialAssignmentStrategies": [
            "started_by"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT48H",
          "decisionConditions": {
            "proceed": "appraisal_initiation_check_decisionTaken == 'P'",
            "route_back": "appraisal_initiation_check_decisionTaken == 'R'",
            "cancel": "appraisal_initiation_check_decisionTaken == 'C'"
          },
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "system"
            },
            {
              "value": "R",
              "label": "Route Back",
              "assignmentMode": "system"
            },
            {
              "value": "C",
              "label": "Cancel",
              "assignmentMode": "system"
            }
          ]
        },
        "position": {
          "x": 150,
          "y": 100
        },
        "requiredRoles": [
          "RequestChecker"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "appraisal-initiation",
        "name": "Appraisal Initiation",
        "type": "TaskActivity",
        "description": "Request maker provides additional information when routed back",
        "properties": {
          "activityName": "AppraisalInitiation",
          "assigneeGroup": "RequestMaker",
          "assignmentStrategies": "started_by",
          "initialAssignmentStrategies": [
            "started_by"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT48H",
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "system"
            }
          ],
          "inputMappings": {
            "isPma": "isPma",
            "facilityLimit": "facilityLimit",
            "priority": "priority",
            "hasAppraisalBook": "hasAppraisalBook"
          }
        },
        "position": {
          "x": 150,
          "y": 250
        },
        "requiredRoles": [
          "RequestMaker"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "await-appraisal-created",
        "name": "Await Appraisal Created",
        "type": "AwaitSignalActivity",
        "description": "Suspends workflow until the Appraisal aggregate is created by the async handler",
        "properties": {
          "signalName": "AppraisalCreated",
          "correlationKey": "requestId",
          "completionVariable": "appraisalId"
        },
        "position": {
          "x": 175,
          "y": 100
        },
        "requiredRoles": [],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "initial-routing",
        "name": "Initial Routing",
        "type": "RoutingActivity",
        "description": "Evaluates routing conditions to determine workflow path — auto-assign to external company or route to internal admin",
        "properties": {
          "routingConditions": {
            "auto_assign_external": "facilityLimit > 50000000",
            "auto_assign_internal": "hasAppraisalBook == true || isPma == true",
            "admin_review": "priority == 'high'"
          },
          "defaultDecision": "auto_assign_external"
        },
        "position": {
          "x": 200,
          "y": 100
        },
        "requiredRoles": [],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "appraisal-assignment",
        "name": "Appraisal Assignment",
        "type": "TaskActivity",
        "description": "Internal admin reviews the request and decides to assign to external company or internal appraisal",
        "properties": {
          "activityName": "AppraisalAssignment",
          "assigneeGroup": "Admin",
          "assignmentStrategies": "pool",
          "initialAssignmentStrategies": [
            "pool"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT72H",
          "decisionConditions": {
            "route_external": "appraisal_assignment_decisionTaken == 'EXT'",
            "route_internal": "appraisal_assignment_decisionTaken == 'INT'",
            "reject": "appraisal_assignment_decisionTaken == 'REJ'",
            "request_more_info": "appraisal_assignment_decisionTaken == 'R'",
            "proceed": "appraisal_assignment_decisionTaken == 'P'"
          },
          "actions": [
            {
              "value": "EXT",
              "label": "Route to External",
              "assignmentMode": "user"
            },
            {
              "value": "INT",
              "label": "Route to Internal",
              "assignmentMode": "user"
            },
            {
              "value": "REJ",
              "label": "Reject",
              "assignmentMode": "system"
            },
            {
              "value": "R",
              "label": "Request More Info",
              "assignmentMode": "system"
            },
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "system",
              "condition": "assignmentType == 'External' || assignmentType == 'Internal'"
            }
          ],
          "inputMappings": {
            "assignmentMethod": "assignmentMethod",
            "selectedCompanyId": "selectedCompanyId",
            "selectedCompanyName": "selectedCompanyName",
            "internalFollowupStaffId": "internalFollowupStaffId",
            "internalFollowupMethod": "internalFollowupMethod"
          }
        },
        "position": {
          "x": 300,
          "y": 100
        },
        "requiredRoles": [
          "Admin"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "company-selection",
        "name": "Company Selection",
        "type": "CompanySelectionActivity",
        "description": "Selects external company via round-robin or manual assignment",
        "properties": {},
        "position": {
          "x": 300,
          "y": 175
        },
        "requiredRoles": [],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "internal-followup-selection",
        "name": "Internal Followup Selection",
        "type": "InternalFollowupSelectionActivity",
        "description": "Selects internal followup staff via round-robin or uses admin-selected staff",
        "properties": {},
        "position": {
          "x": 300,
          "y": 193
        },
        "requiredRoles": [],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "ext-appraisal-assignment",
        "name": "External Appraisal Assignment",
        "type": "TaskActivity",
        "description": "External company admin handles appointment, fee, and assigns to company appraiser",
        "properties": {
          "activityName": "ExtAppraisalAssignment",
          "assigneeGroup": "ExtAdmin",
          "teamIdVariable": "assignedCompanyId",
          "assignmentRules": {
            "teamConstrained": true
          },
          "assignmentStrategies": "round_robin",
          "initialAssignmentStrategies": [
            "round_robin"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT48H",
          "decisionConditions": {
            "proceed": "ext_appraisal_assignment_decisionTaken == 'P'",
            "cancel": "ext_appraisal_assignment_decisionTaken == 'C'",
            "route_back": "ext_appraisal_assignment_decisionTaken == 'R'"
          },
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "user"
            },
            {
              "value": "C",
              "label": "Cancel",
              "assignmentMode": "system"
            },
            {
              "value": "R",
              "label": "Route Back",
              "assignmentMode": "system"
            }
          ]
        },
        "position": {
          "x": 300,
          "y": 212
        },
        "requiredRoles": [
          "ExtAdmin"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "ext-appraisal-execution",
        "name": "External Appraisal Execution",
        "type": "TaskActivity",
        "description": "External appraiser conducts the property appraisal",
        "properties": {
          "activityName": "ExtAppraisalExecution",
          "assigneeGroup": "ExtAppraisalStaff",
          "teamIdVariable": "assignedCompanyId",
          "assignmentRules": {
            "teamConstrained": true
          },
          "assignmentStrategies": "round_robin",
          "initialAssignmentStrategies": [
            "round_robin"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT72H",
          "decisionConditions": {
            "proceed": "ext_appraisal_execution_decisionTaken == 'P'",
            "route_back": "ext_appraisal_execution_decisionTaken == 'R'"
          },
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "user"
            },
            {
              "value": "R",
              "label": "Route Back",
              "assignmentMode": "system"
            }
          ]
        },
        "position": {
          "x": 300,
          "y": 250
        },
        "requiredRoles": [
          "ExtAppraisalStaff"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "ext-appraisal-check",
        "name": "External Appraisal Check",
        "type": "TaskActivity",
        "description": "External checker reviews the appraisal work for accuracy and completeness",
        "properties": {
          "activityName": "ExtAppraisalCheck",
          "assigneeGroup": "ExtAppraisalChecker",
          "teamIdVariable": "assignedCompanyId",
          "assignmentRules": {
            "teamConstrained": true
          },
          "assignmentStrategies": "round_robin",
          "initialAssignmentStrategies": [
            "round_robin"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT48H",
          "decisionConditions": {
            "proceed": "ext_appraisal_check_decisionTaken == 'P'",
            "route_back": "ext_appraisal_check_decisionTaken == 'R'"
          },
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "user"
            },
            {
              "value": "R",
              "label": "Route Back",
              "assignmentMode": "system"
            }
          ]
        },
        "position": {
          "x": 300,
          "y": 400
        },
        "requiredRoles": [
          "ExtAppraisalChecker"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "ext-appraisal-verification",
        "name": "External Appraisal Verification",
        "type": "TaskActivity",
        "description": "External verifier performs final verification before handoff to internal",
        "properties": {
          "activityName": "ExtAppraisalVerification",
          "assigneeGroup": "ExtAppraisalVerifier",
          "teamIdVariable": "assignedCompanyId",
          "assignmentRules": {
            "teamConstrained": true
          },
          "assignmentStrategies": "round_robin",
          "initialAssignmentStrategies": [
            "round_robin"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT24H",
          "decisionConditions": {
            "proceed": "ext_appraisal_verification_decisionTaken == 'P'",
            "route_back": "ext_appraisal_verification_decisionTaken == 'R'"
          },
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "system"
            },
            {
              "value": "R",
              "label": "Route Back",
              "assignmentMode": "system"
            }
          ]
        },
        "position": {
          "x": 300,
          "y": 550
        },
        "requiredRoles": [
          "ExtAppraisalVerifier"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "appraisal-book-verification",
        "name": "Appraisal Book Verification",
        "type": "TaskActivity",
        "description": "Internal appraisal staff verifies the external company appraisal book",
        "properties": {
          "activityName": "AppraisalBookVerification",
          "assigneeGroup": "IntAppraisalStaff",
          "assignmentStrategies": "variable_assignee",
          "initialAssignmentStrategies": [
            "variable_assignee",
            "round_robin"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "assigneeVariable": "internalFollowupStaffId",
          "timeoutDuration": "PT72H",
          "decisionConditions": {
            "proceed": "appraisal_book_verification_decisionTaken == 'P'",
            "route_back_ext_admin": "appraisal_book_verification_decisionTaken == 'R_EA'",
            "route_back_ext_checker": "appraisal_book_verification_decisionTaken == 'R_EC'"
          },
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "system"
            },
            {
              "value": "R_EA",
              "label": "Route Back to External Admin",
              "assignmentMode": "system"
            },
            {
              "value": "R_EC",
              "label": "Route Back to External Checker",
              "assignmentMode": "system"
            }
          ]
        },
        "position": {
          "x": 300,
          "y": 650
        },
        "requiredRoles": [
          "IntAppraisalStaff"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "int-appraisal-execution",
        "name": "Internal Appraisal Execution",
        "type": "TaskActivity",
        "description": "Internal appraisal staff conducts the property appraisal",
        "properties": {
          "activityName": "IntAppraisalExecution",
          "assigneeGroup": "IntAppraisalStaff",
          "assignmentStrategies": "round_robin",
          "initialAssignmentStrategies": [
            "round_robin"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT72H",
          "decisionConditions": {
            "proceed": "int_appraisal_execution_decisionTaken == 'P'",
            "route_back": "int_appraisal_execution_decisionTaken == 'R'"
          },
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "system"
            },
            {
              "value": "R",
              "label": "Route Back",
              "assignmentMode": "system"
            }
          ]
        },
        "position": {
          "x": 300,
          "y": 750
        },
        "requiredRoles": [
          "IntAppraisalStaff"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "int-appraisal-check",
        "name": "Internal Appraisal Check",
        "type": "TaskActivity",
        "description": "Internal checker reviews the appraisal work for accuracy and completeness",
        "properties": {
          "activityName": "IntAppraisalCheck",
          "assigneeGroup": "IntAppraisalChecker",
          "assignmentRules": {
            "teamConstrained": true
          },
          "assignmentStrategies": "round_robin",
          "initialAssignmentStrategies": [
            "round_robin"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT48H",
          "decisionConditions": {
            "proceed": "int_appraisal_check_decisionTaken == 'P'",
            "route_back": "int_appraisal_check_decisionTaken == 'R'"
          },
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "system"
            },
            {
              "value": "R",
              "label": "Route Back",
              "assignmentMode": "system"
            }
          ]
        },
        "position": {
          "x": 300,
          "y": 850
        },
        "requiredRoles": [
          "IntAppraisalChecker"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "int-appraisal-verification",
        "name": "Internal Appraisal Verification",
        "type": "TaskActivity",
        "description": "Internal verifier performs final verification and sign-off",
        "properties": {
          "activityName": "IntAppraisalVerification",
          "assigneeGroup": "IntAppraisalVerifier",
          "assignmentRules": {
            "teamConstrained": true
          },
          "assignmentStrategies": "round_robin",
          "initialAssignmentStrategies": [
            "round_robin"
          ],
          "revisitAssignmentStrategies": [
            "previous_owner"
          ],
          "timeoutDuration": "PT24H",
          "decisionConditions": {
            "proceed": "int_appraisal_verification_decisionTaken == 'P'",
            "route_back": "int_appraisal_verification_decisionTaken == 'R'"
          },
          "actions": [
            {
              "value": "P",
              "label": "Proceed",
              "assignmentMode": "system"
            },
            {
              "value": "R",
              "label": "Route Back",
              "assignmentMode": "system"
            }
          ]
        },
        "position": {
          "x": 300,
          "y": 1000
        },
        "requiredRoles": [
          "IntAppraisalVerifier"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "approval-tier-switch",
        "name": "Approval Tier Routing",
        "type": "SwitchActivity",
        "description": "Routes appraisal to a meeting (>30M) or directly to committee approval based on facility limit",
        "properties": {
          "expression": "facilityLimit",
          "cases": [
            "<= 30000000",
            "> 30000000"
          ]
        },
        "position": {
          "x": 300,
          "y": 1050
        },
        "requiredRoles": [],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "pending-meeting",
        "name": "Pending Meeting",
        "type": "MeetingActivity",
        "description": "Waits for the Meeting Secretary to schedule and end an approval meeting for this appraisal",
        "properties": {},
        "position": {
          "x": 500,
          "y": 1100
        },
        "requiredRoles": [
          "MeetingSecretary"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "pending-approval",
        "name": "Committee Approval",
        "type": "ApprovalActivity",
        "description": "Appraisal committee reviews and votes — quorum and majority rules apply",
        "properties": {
          "activityName": "PendingApproval",
          "voteOptions": [
            "approve",
            "reject",
            "route_back"
          ],
          "memberSource": {
            "type": "threshold",
            "valueExpression": "facilityLimit",
            "thresholds": [
              {
                "maxValue": 10000000,
                "committeeCode": "SUB_COMMITTEE"
              },
              {
                "maxValue": 30000000,
                "committeeCode": "COMMITTEE"
              },
              {
                "maxValue": null,
                "committeeCode": "COMMITTEE_WITH_MEETING"
              }
            ]
          },
          "timeoutDuration": "PT72H",
          "decisionConditions": {
            "approve": "pending_approval_decision == 'approve'",
            "route_back": "pending_approval_decision == 'route_back'"
          }
        },
        "position": {
          "x": 300,
          "y": 1150
        },
        "requiredRoles": [
          "AppraisalCommittee"
        ],
        "isStartActivity": false,
        "isEndActivity": false
      },
      {
        "id": "workflow-completed",
        "name": "Appraisal Completed",
        "type": "EndActivity",
        "description": "Appraisal process successfully completed",
        "properties": {
          "completionMessage": "Appraisal has been successfully completed and approved"
        },
        "position": {
          "x": 300,
          "y": 1300
        },
        "requiredRoles": [],
        "isStartActivity": false,
        "isEndActivity": true
      },
      {
        "id": "workflow-rejected",
        "name": "Request Rejected",
        "type": "EndActivity",
        "description": "Request has been rejected or cancelled",
        "properties": {
          "completionMessage": "Request has been rejected and workflow terminated"
        },
        "position": {
          "x": 700,
          "y": 900
        },
        "requiredRoles": [],
        "isStartActivity": false,
        "isEndActivity": true
      }
    ],
    "transitions": [
      {
        "id": "start-to-appraisal-initiation-check",
        "from": "start",
        "to": "appraisal-initiation-check",
        "condition": "channel == 'MANUAL'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "start-to-await-appraisal-created",
        "from": "start",
        "to": "await-appraisal-created",
        "condition": "channel != 'MANUAL'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "appraisal-initiation-check-proceed",
        "from": "appraisal-initiation-check",
        "to": "await-appraisal-created",
        "condition": "decision == 'proceed'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "await-appraisal-created-to-routing",
        "from": "await-appraisal-created",
        "to": "initial-routing",
        "condition": null,
        "properties": {},
        "type": "Normal"
      },
      {
        "id": "appraisal-initiation-check-route-back",
        "from": "appraisal-initiation-check",
        "to": "appraisal-initiation",
        "condition": "decision == 'route_back'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "appraisal-initiation-check-cancel",
        "from": "appraisal-initiation-check",
        "to": "workflow-rejected",
        "condition": "decision == 'cancel'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "appraisal-initiation-to-appraisal-initiation-check",
        "from": "appraisal-initiation",
        "to": "appraisal-initiation-check",
        "condition": null,
        "properties": {},
        "type": "Normal"
      },
      {
        "id": "routing-to-admin",
        "from": "initial-routing",
        "to": "appraisal-assignment",
        "condition": "decision == 'admin_review'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "routing-to-company-selection",
        "from": "initial-routing",
        "to": "company-selection",
        "condition": "decision == 'auto_assign_external'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "routing-to-internal",
        "from": "initial-routing",
        "to": "int-appraisal-execution",
        "condition": "decision == 'auto_assign_internal'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "admin-route-external",
        "from": "appraisal-assignment",
        "to": "company-selection",
        "condition": "decision == 'route_external'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "admin-route-internal",
        "from": "appraisal-assignment",
        "to": "int-appraisal-execution",
        "condition": "decision == 'route_internal'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "admin-reject",
        "from": "appraisal-assignment",
        "to": "workflow-rejected",
        "condition": "decision == 'reject'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "admin-request-info",
        "from": "appraisal-assignment",
        "to": "appraisal-initiation",
        "condition": "decision == 'request_more_info'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "admin-proceed-external",
        "from": "appraisal-assignment",
        "to": "company-selection",
        "condition": "decision == 'proceed' && assignmentType == 'External'",
        "properties": {},
        "type": "Conditional"
      },
      {
        "id": "admin-proceed-internal",
        "from": "appraisal-assignment",
        "to": "int-appraisal-execution",
        "condition": "decision == 'proceed' && assignmentType == 'Internal'",
        "properties": {},
