@page
@model Auth.Pages.Account.Login
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="initial-scale=1, width=device-width">

    <link rel="stylesheet" href="/Assets/index.css"/>

    <title>Login</title>
</head>

<body>
<div class="login">
    <div class="login-image">
        <img src="/Assets/Bangkok skyline view.png" alt="Bangkok skyline">
    </div>
    <div class="login-panel">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" value="@Model.ReturnUrl"/>

            <svg class="login-logo" viewBox="0 0 242 59" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="LH Bank">
                <g clip-path="url(#clip0_5389_891)">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M0 59.0479H7.337V46.5123H0V59.0479Z" fill="#CED629"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M7.33691 59.0479H14.6776V46.5123H7.33691V59.0479Z" fill="#47B9C0"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M14.6758 59.0479H22.0128V46.5123H14.6758V59.0479Z" fill="#8B3F92"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M22.0129 59.0479H29.3499V46.5123H22.0129V59.0479Z" fill="#ED8068"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M29.3517 59.0479H36.6887V46.5123H29.3499L29.3517 59.0479Z" fill="#0080BE"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M36.6851 59.0479H44.0257V46.5123H36.6851V59.0479Z" fill="#F5BF0E"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M44.0256 59.0479H51.3626V46.5123H44.0256V59.0479Z" fill="#94988D"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M51.3625 59.0479H58.7014V46.5123H51.3625V59.0479Z" fill="#F08D1D"/>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M107.567 31.5097H98.3217V19.5622H107.567C110.061 19.5622 112.02 20.0821 113.388 21.1109C114.745 22.1287 115.405 23.5189 115.405 25.3552C115.405 29.4963 112.84 31.5097 107.567 31.5097ZM112.468 13.9904C111.36 14.9362 109.71 15.4156 107.567 15.4156H98.3217V4.90622H107.567C111.971 4.90622 114.112 6.70019 114.112 10.3951C114.112 11.8701 113.573 13.0464 112.468 13.9904ZM119.484 22.4348C119.201 21.51 118.773 20.6367 118.215 19.848C117.269 18.4965 116.048 17.5433 114.58 17.0031C115.69 16.3441 116.619 15.4169 117.282 14.3057C118.169 12.8196 118.622 11.2542 118.622 9.64834C118.622 6.51766 117.48 4.16134 115.223 2.64209C113.335 1.39203 110.761 0.761469 107.567 0.761469H93.9272V35.601H107.567C112.402 35.601 115.892 34.3011 117.946 31.7346C119.253 30.0587 119.915 27.931 119.915 25.4106C119.915 24.3688 119.77 23.3677 119.484 22.4348ZM194.11 0.759626V27.8038L175.655 0.757782L170.731 0.759626V35.601H175.624V8.44991L194.08 35.601H199.005V0.759626H194.11ZM226.156 15.3068L241.094 0.759626H235.11L218.024 17.2169V0.759626H213.743V35.6028H218.024V23.447L222.801 18.443L236.02 35.6065L241.661 35.601L226.156 15.3068ZM147.209 0.759626H142.69L128.775 35.601L133.866 35.6028L137.647 24.9533L144.848 6.04013L155.742 35.5936L160.657 35.6028L147.209 0.759626Z" fill="#ffffff"/>
                    <mask id="mask0_5389_891" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="242" height="60">
                        <path d="M0 59.0479H241.663V0H0V59.0479Z" fill="white"/>
                    </mask>
                    <g mask="url(#mask0_5389_891)">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M135.256 27.5401H154.27V23.7475H135.256V27.5401Z" fill="#ffffff"/>
                    </g>
                    <mask id="mask1_5389_891" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="242" height="60">
                        <path d="M0 59.0479H241.663V0H0V59.0479Z" fill="white"/>
                    </mask>
                    <g mask="url(#mask1_5389_891)">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M5.58247 0H0.119141V35.6323H22.385V31.0137H5.58247V0ZM54.1273 0V13.7949H37.279V0H31.8156V35.6323H37.279V18.4117H54.1273V35.6323H59.5906V0H54.1273Z" fill="#ffffff"/>
                    </g>
                </g>
                <defs>
                    <clipPath id="clip0_5389_891">
                        <rect width="242" height="59" fill="white"/>
                    </clipPath>
                </defs>
            </svg>
            <h1 class="login-title">Collateral Appraisal System</h1>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="error-message">@Model.Error</div>
            }

            <div class="input-container">
                <label class="input-label" for="name">Username</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                    <input class="text-input" type="text" id="name" name="Username" value="@Model.Username"
                           placeholder="Enter your username" autocomplete="username" required>
                </div>
            </div>

            <div class="input-container">
                <label class="input-label" for="password">Password</label>
                <div class="input-wrapper">
                    <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input class="text-input" type="password" id="password" name="Password" value="@Model.Password"
                           placeholder="Enter your password" autocomplete="current-password" required>
                    <button type="button" class="eye-toggle" onclick="togglePassword()"
                            aria-label="Toggle password visibility">
                        <svg class="eye-icon eye-open" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg class="eye-icon eye-closed" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" style="display:none;">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                            <path d="M1 1l22 22"/>
                            <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="login-button-container">
                <button type="submit" class="login-button">Sign In</button>
            </div>
        </form>
    </div>
</div>
<script>
    function togglePassword() {
        var input = document.getElementById('password');
        var open = document.querySelector('.eye-open');
        var closed = document.querySelector('.eye-closed');
        if (input.type === 'password') {
            input.type = 'text';
            open.style.display = 'none';
            closed.style.display = 'block';
        } else {
            input.type = 'password';
            open.style.display = 'block';
            closed.style.display = 'none';
        }
    }

    document.querySelector('form').addEventListener('submit', function () {
        var btn = document.querySelector('.login-button');
        btn.disabled = true;
        btn.textContent = 'Signing in...';
        btn.classList.add('loading');
    });
</script>
</body>

</html>
