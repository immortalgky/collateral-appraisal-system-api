{
  "ConnectionStrings": {
    "Database": "Server=localhost;Database=CollateralAppraisal;User Id=sa;Password=P@ssw0rd;TrustServerCertificate=True;",
    "Redis": "localhost:6379",
    "Hangfire": "Server=localhost;Database=CollateralAppraisal;User Id=sa;Password=P@ssw0rd;TrustServerCertificate=True;"
  },
  "RabbitMQ": {
    "Host": "amqp://localhost:5672/",
    "Username": "admin",
    "Password": "P@ssw0rd"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Grafana.Loki",
      "Serilog.Sinks.MSSqlServer"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "MassTransit": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://localhost:3100",
          "labels": [
            {
              "key": "app",
              "value": "collateral-appraisal-system"
            },
            {
              "key": "environment",
              "value": "Development"
            }
          ],
          "propertiesAsLabels": [
            "Application"
          ]
        }
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Database",
          "sinkOptionsSection": {
            "tableName": "Logs",
            "schemaName": "dbo",
            "autoCreateSqlTable": false,
            "batchPostingLimit": 200,
            "period": "0.00:00:05"
          },
          "restrictedToMinimumLevel": "Information",
          "columnOptionsSection": {
            "disableTriggers": true,
            "addStandardColumns": [ "LogEvent" ],
            "removeStandardColumns": [ "MessageTemplate", "Properties" ],
            "timeStamp": { "columnName": "TimeStamp", "convertToUtc": false },
            "logEvent": { "columnName": "Properties" },
            "additionalColumns": [
              { "ColumnName": "CorrelationId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "EntityId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "AppraisalId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "RequestId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "WorkflowInstanceId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "CollateralId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "DocumentId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "MachineName", "DataType": "nvarchar", "DataLength": 128 }
            ]
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "CollateralAppraisalSystem"
    }
  },
  "Identity": {
    "Lockout": {
      "MaxFailedAccessAttempts": 5,
      "PermanentLockout": true,
      "LockoutEnabled": true
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:3000",
      "https://localhost:7111"
    ]
  },
  "AppBaseUrl": "https://localhost:7111",
  "AllowedHosts": "*",
  "SeedData": {
    "AdminUser": {
      "Username": "admin",
      "Password": "P@ssw0rd!"
    }
  },
  "TimeZone": {
    "DefaultTimeZone": "Asia/Bangkok",
    "ForceUtc": false,
    "Culture": "en-US",
    "DateFormat": "yyyy-MM-dd",
    "TimeFormat": "HH:mm:ss",
    "DateTimeFormat": "yyyy-MM-dd HH:mm:ss"
  },
  "Observability": {
    "Enabled": true,
    "ServiceName": "CollateralAppraisalSystem",
    "ServiceVersion": "1.0.0",
    "Tracing": {
      "OtlpEndpoint": "http://localhost:4317"
    }
  },
  "Workflow": {
    "AcknowledgementGroupByCommitteeCode": {
      "SUB_COMMITTEE": "1",
      "COMMITTEE": "2"
    }
  },
  "WorkflowResilience": {
    "Retry": {
      "MaxRetryAttempts": 3,
      "BaseDelay": "00:00:01",
      "MaxDelay": "00:00:30"
    },
    "Timeout": {
      "DatabaseOperation": "00:00:30",
      "ExternalHttpCall": "00:00:10",
      "ActivityExecution": "00:05:00"
    },
    "CircuitBreaker": {
      "MinimumThroughput": 10,
      "BreakDuration": "00:00:30"
    }
  },
  "Reporting": {
    "ChromiumExecutablePath": "",
    "MaxConcurrentPages": 4
  },
  "Mail": {
    "Host": "localhost",
    "Port": 2525,
    "UseStartTls": false,
    "Username": "",
    "Password": "",
    "FromAddress": "appraisal-dev@localhost",
    "FromDisplayName": "Collateral Appraisal System (Dev)",
    "Enabled": true
  }
}