{
  "ConnectionStrings": {
    "Database": "Server=localhost;Database=<Database>;User Id=<User Id>;Password=<Password>;TrustServerCertificate=True;",
    "Redis": "localhost:6379",
    "Hangfire": "Server=localhost;Database=<Database>;User Id=<User Id>;Password=<Password>;TrustServerCertificate=True;"
  },
  "RabbitMQ": {
    "Host": "amqp://localhost:5672/",
    "Username": "<RABBITMQ_USERNAME>",
    "Password": "<RABBITMQ_PASSWORD>"
  },
  "OAuth2": {
    "SigningCertificate": {
      "Source": "store",
      "StoreName": "My",
      "StoreLocation": "LocalMachine",
      "Thumbprint": "<SIGNING_CERT_THUMBPRINT>"
    },
    "EncryptionCertificate": {
      "Source": "store",
      "StoreName": "My",
      "StoreLocation": "LocalMachine",
      "Thumbprint": "<ENCRYPTION_CERT_THUMBPRINT>"
    }
  },
  "SeedData": {
    "AdminUser": {
      "Username": "<ADMIN_USERNAME>",
      "Password": "<ADMIN_PASSWORD>"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Grafana.Loki"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://localhost:3100",
          "labels": [
            { "key": "app", "value": "collateral-appraisal-system" },
            { "key": "environment", "value": "Production" }
          ],
          "propertiesAsLabels": [ "Application" ]
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "CollateralAppraisalSystem"
    }
  },
  "Ldap": {
    "Enabled": false,
    "Server": "ad.bank.co.th",
    "Port": 636,
    "UseSsl": true,
    "BaseDn": "DC=bank,DC=co,DC=th",
    "BindDn": "CN=svc-cas,OU=ServiceAccounts,DC=bank,DC=co,DC=th",
    "BindPassword": "",
    "SearchFilter": "(sAMAccountName={0})",
    "FallbackToLocalAuth": true,
    "ConnectionTimeoutSeconds": 5,
    "Attributes": {
      "Username": "sAMAccountName",
      "Email": "mail",
      "FirstName": "givenName",
      "LastName": "sn",
      "Department": "department",
      "Position": "title"
    }
  },
  "Identity": {
    "Lockout": {
      "MaxFailedAccessAttempts": 5,
      "PermanentLockout": true,
      "LockoutEnabled": true
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "AppBaseUrl": "<APP_BASE_URL>",
  "Observability": {
    "Enabled": true,
    "ServiceName": "CollateralAppraisalSystem",
    "ServiceVersion": "1.0.0",
    "Tracing": {
      "OtlpEndpoint": null
    }
  },
  "Workflow": {
    "SecretaryPerItemEnabled": true,
    "AcknowledgementGroupByCommitteeCode": {
      "SUB": "Group1",
      "GRP1": "Group1",
      "UG2": "UrgentGroup2"
    }
  },
  "AllowedHosts": "*",
  "TimeZone": {
    "DefaultTimeZone": "Asia/Bangkok",
    "ForceUtc": false,
    "Culture": "en-US",
    "DateFormat": "yyyy-MM-dd",
    "TimeFormat": "HH:mm:ss",
    "DateTimeFormat": "yyyy-MM-dd HH:mm:ss"
  },
  "FileStorage": {
    "Mode": "Local",
    "NasBasePath": "\\\\nas_app_dev\\CAS",
    "RootPath": "uploads",
    "TempPath": "temp",
    "DocumentsPath": "documents",
    "ArchivePath": "archive",
    "DeletedPath": "deleted",
    "MaxFileSizeBytes": 52428800,
    "MaxFilesPerSession": 20,
    "MaxTotalSessionSizeBytes": 209715200,
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".pdf",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".tif",
      ".tiff"
    ],
    "ImageVariants": {
      "GenerateThumbnails": true,
      "Sizes": {
        "Small": {
          "Width": 150,
          "Height": 150
        },
        "Medium": {
          "Width": 300,
          "Height": 300
        },
        "Large": {
          "Width": 800,
          "Height": 600
        }
      }
    },
    "Cleanup": {
      "TempSessionExpirationHours": 24,
      "DeletedRetentionDays": 30,
      "OrphanedCheckDays": 7
    },
    "Archive": {
      "ArchiveAfterDays": 365,
      "AutoArchiveEnabled": true
    }
  }
}
