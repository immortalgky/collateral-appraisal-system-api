{
  "ConnectionStrings": {
    "Database": "Server=localhost;Database=<Database>;User Id=<User Id>;Password=<Password>;TrustServerCertificate=True;",
    "Redis": "localhost:6379",
    "Hangfire": "Server=localhost;Database=<Database>;User Id=<User Id>;Password=<Password>;TrustServerCertificate=True;"
  },
  "RabbitMQ": {
    "Host": "amqp://localhost:5672/",
    "Username": "<RABBITMQ_USERNAME>",
    "Password": "<RABBITMQ_PASSWORD>"
  },
  "OAuth2": {
    "SigningCertificate": {
      "Source": "store",
      "StoreName": "My",
      "StoreLocation": "LocalMachine",
      "Thumbprint": "<SIGNING_CERT_THUMBPRINT>"
    },
    "EncryptionCertificate": {
      "Source": "store",
      "StoreName": "My",
      "StoreLocation": "LocalMachine",
      "Thumbprint": "<ENCRYPTION_CERT_THUMBPRINT>"
    }
  },
  "SeedData": {
    "AdminUser": {
      "Username": "<ADMIN_USERNAME>",
      "Password": "<ADMIN_PASSWORD>"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Grafana.Loki",
      "Serilog.Sinks.MSSqlServer"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "MassTransit": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://localhost:3100",
          "labels": [
            {
              "key": "app",
              "value": "collateral-appraisal-system"
            },
            {
              "key": "environment",
              "value": "Production"
            }
          ],
          "propertiesAsLabels": [
            "Application"
          ]
        }
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Database",
          "sinkOptionsSection": {
            "tableName": "Logs",
            "schemaName": "dbo",
            "autoCreateSqlTable": false,
            "batchPostingLimit": 200,
            "period": "0.00:00:05"
          },
          "restrictedToMinimumLevel": "Information",
          "columnOptionsSection": {
            "disableTriggers": true,
            "addStandardColumns": [ "LogEvent" ],
            "removeStandardColumns": [ "MessageTemplate", "Properties" ],
            "timeStamp": { "columnName": "TimeStamp", "convertToUtc": false },
            "logEvent": { "columnName": "Properties" },
            "additionalColumns": [
              { "ColumnName": "CorrelationId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "EntityId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "AppraisalId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "RequestId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "WorkflowInstanceId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "CollateralId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "DocumentId", "DataType": "nvarchar", "DataLength": 64 },
              { "ColumnName": "MachineName", "DataType": "nvarchar", "DataLength": 128 }
            ]
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "CollateralAppraisalSystem"
    }
  },
  "Ldap": {
    "Enabled": false,
    "Server": "LHB.NET",
    "Port": 389,
    "UseSsl": false,
    "UseIntegratedAuth": true,
    "Domain": "LHB",
    "BaseDn": "DC=LHB,DC=NET",
    "BindDn": "",
    "BindPassword": "",
    "SearchFilter": "(sAMAccountName={0})",
    "ConnectionTimeoutSeconds": 5,
    "Attributes": {
      "Username": "sAMAccountName",
      "Email": "mail",
      "FirstName": "givenName",
      "LastName": "sn",
      "Department": "department",
      "Position": "title"
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "AppBaseUrl": "<APP_BASE_URL>",
  "Observability": {
    "Enabled": true,
    "ServiceName": "CollateralAppraisalSystem",
    "ServiceVersion": "1.0.0",
    "Tracing": {
      "OtlpEndpoint": null
    }
  },
  "Workflow": {
    "AcknowledgementGroupByCommitteeCode": {
      "SUB_COMMITTEE": "1",
      "COMMITTEE": "2"
    }
  },
  "SignalR": {
    "UseRedisBackplane": true,
    "ChannelPrefix": "cas"
  },
  "AllowedHosts": "*",
  "TimeZone": {
    "DefaultTimeZone": "Asia/Bangkok",
    "ForceUtc": false,
    "Culture": "en-US",
    "DateFormat": "yyyy-MM-dd",
    "TimeFormat": "HH:mm:ss",
    "DateTimeFormat": "yyyy-MM-dd HH:mm:ss"
  },
  "FileStorage": {
    "Mode": "Local",
    "NasBasePath": "\\\\nas_app_dev\\CAS",
    "RootPath": "uploads",
    "TempPath": "temp",
    "DocumentsPath": "documents",
    "ArchivePath": "archive",
    "DeletedPath": "deleted",
    "MaxFileSizeBytes": 52428800,
    "MaxFilesPerSession": 20,
    "MaxTotalSessionSizeBytes": 209715200,
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".pdf",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".tif",
      ".tiff"
    ],
    "ImageVariants": {
      "GenerateThumbnails": true,
      "Sizes": {
        "Small": {
          "Width": 150,
          "Height": 150
        },
        "Medium": {
          "Width": 300,
          "Height": 300
        },
        "Large": {
          "Width": 800,
          "Height": 600
        }
      }
    },
    "Cleanup": {
      "TempSessionExpirationHours": 24,
      "DeletedRetentionDays": 30,
      "OrphanedCheckDays": 7
    },
    "Archive": {
      "ArchiveAfterDays": 365,
      "AutoArchiveEnabled": true
    }
  },
  "Reporting": {
    "ChromiumExecutablePath": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
    "MaxConcurrentPages": 4
  },
  "FileTransfer": {
    "Inbound": { "FileSource": "Local", "Sftp": { "Host": "", "Port": 22, "Username": "", "Password": "" } },
    "Outbound": { "FileSource": "Local", "Sftp": { "Host": "", "Port": 22, "Username": "", "Password": "" } }
  },
  "Mail": {
    "Host": "f5mailgw.lhbank.co.th",
    "Port": 587,
    "UseStartTls": true,
    "Username": "AdminAppraisalUAT",
    "Password": "Lhb1234+",
    "FromAddress": "AdminAppraisalUAT@lhbank.co.th",
    "FromDisplayName": "Collateral Appraisal System",
    "Enabled": true
  }
}
