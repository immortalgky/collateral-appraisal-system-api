# -------------------------------------
# .NET Core / ASP.NET Core
# -------------------------------------
bin/
obj/
out/
[Ll]og/

# macOS system files
.DS_Store

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio
.vs/
.vsconfig

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Environment files
.env
.env.*

# NuGet
*.nupkg
*.snupkg
*.nuspec
project.lock.json
project.fragment.lock.json
artifacts/

# Publish output
wwwroot/dist/
wwwroot/node_modules/
node_modules/
dist/
TestResults/

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Backup & misc
*.bak
*.old
*.orig
*.swp
*.tmp
*.tmp.*

# Database backups
Database/Backups/

# SqlProj publish output
Database/publish/

# -------------------------------------
# Docker (keep Dockerfile & docker-compose.yml)
# -------------------------------------
.dockerignore
**/.docker/         # Only ignore custom internal docker folders, not Dockerfile

# Optional: ignore generated Docker volume folders (if any)
docker-volumes/

# -------------------------------------
# Runtime user uploads (local-only; never commit)
# -------------------------------------
Bootstrapper/Api/wwwroot/uploads/documents/
Bootstrapper/Api/wwwroot/uploads/reports/

# -------------------------------------
# File-interface job runtime dirs (side-effects of local Hangfire runs;
# committed sample fixtures inside stay tracked — gitignore only hides new files)
# -------------------------------------
Bootstrapper/Api/outbound/
Bootstrapper/Api/reappraisal/

# Python bytecode (docs/reappraisal data generators)
__pycache__/

# Security-review patch bundles (redundant with the actual commits)
docs/security-review/*.patch

# -------------------------------------
# Local Claude artifacts (local-only)
# -------------------------------------
.claude/worktrees/
.claude/docs/
